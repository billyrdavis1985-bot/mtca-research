        "outputId": "2a59f68f-6bb0-46f5-d6c7-37e1e79f795f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dispatchers ready with provider-specific token limits:\n",
            "  anthropic: 1500 max_tokens\n",
            "  openai: 1500 max_tokens\n",
            "  google: 2500 max_tokens\n",
            "  xai: 1500 max_tokens\n",
            "  deepseek: 1500 max_tokens\n"
          ]
        }
      ],
      "source": [
        "# Provider-specific max_tokens from pilot lessons\n",
        "MAX_TOKENS_BY_PROVIDER = {\n",
        "    'anthropic': 1500,\n",
        "    'openai': 1500,\n",
        "    'google': 2500,    # Gemini Flash is verbose; needs more headroom\n",
        "    'xai': 1500,\n",
        "    'deepseek': 1500,\n",
        "}\n",
        "\n",
        "REQUEST_TIMEOUT = 60  # seconds\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class CouncilResponse:\n",
        "    call_id: str\n",
        "    unit_id: str\n",
        "    text_id: str\n",
        "    frame_id: str\n",
        "    frame_version: str\n",
        "    prompt_sha256: str\n",
        "    model_id: str\n",
        "    provider: str\n",
        "    api_model: str\n",
        "    timestamp: str\n",
        "    wall_clock_seconds: float\n",
        "    raw_response: str\n",
        "    parsed_json: dict = field(default_factory=dict)\n",
        "    parse_succeeded: bool = False\n",
        "    parse_error: str = ''\n",
        "    input_tokens: int = 0\n",
        "    output_tokens: int = 0\n",
        "    error: str = ''\n",
        "    retry_count: int = 0\n",
        "\n",
        "\n",
        "def extract_json_from_response(raw: str) -> tuple:\n",
        "    cleaned = raw.strip()\n",
        "    if cleaned.startswith('```'):\n",
        "        cleaned = re.sub(r'^```(?:json)?\\s*', '', cleaned)\n",
        "        cleaned = re.sub(r'\\s*```$', '', cleaned)\n",
        "    json_start = cleaned.find('{')\n",
        "    json_end = cleaned.rfind('}')\n",
        "    if json_start == -1 or json_end == -1:\n",
        "        return {}, False, 'No JSON object found in response'\n",
        "    json_candidate = cleaned[json_start:json_end + 1]\n",
        "    try:\n",
        "        parsed = json.loads(json_candidate)\n",
        "        expected = {'communicative_function', 'implicit_claims',\n",
        "                    'coherence_assessment', 'conditions_for_usefulness',\n",
        "                    'conditions_for_misleading'}\n",
        "        missing_keys = expected - set(parsed.keys())\n",
        "        if missing_keys:\n",
        "            return parsed, False, f'Missing keys: {missing_keys}'\n",
        "        return parsed, True, ''\n",
        "    except json.JSONDecodeError as e:\n",
        "        return {}, False, f'JSONDecodeError: {str(e)[:100]}'\n",
        "\n",
        "\n",
        "def call_anthropic(api_model: str, prompt: str, max_tokens: int) -> tuple:\n",
        "    try:\n",
        "        resp = anthropic_client.messages.create(\n",
        "            model=api_model,\n",
        "            max_tokens=max_tokens,\n",
        "            messages=[{'role': 'user', 'content': prompt}],\n",
        "            timeout=REQUEST_TIMEOUT\n",
        "        )\n",
        "        return (resp.content[0].text, resp.usage.input_tokens, resp.usage.output_tokens, '')\n",
        "    except Exception as e:\n",
        "        return ('', 0, 0, f'Anthropic error: {type(e).__name__}: {str(e)[:200]}')\n",
        "\n",
        "\n",
        "def call_openai(api_model: str, prompt: str, max_tokens: int) -> tuple:\n",
        "    try:\n",
        "        resp = openai_client.chat.completions.create(\n",
        "            model=api_model,\n",
        "            messages=[{'role': 'user', 'content': prompt}],\n",
        "            max_tokens=max_tokens,\n",
        "            timeout=REQUEST_TIMEOUT\n",
        "        )\n",
        "        return (resp.choices[0].message.content, resp.usage.prompt_tokens, resp.usage.completion_tokens, '')\n",
        "    except Exception as e:\n",
        "        return ('', 0, 0, f'OpenAI error: {type(e).__name__}: {str(e)[:200]}')\n",
        "\n",
        "\n",
        "def call_xai(api_model: str, prompt: str, max_tokens: int) -> tuple:\n",
        "    try:\n",
        "        resp = xai_client.chat.completions.create(\n",
        "            model=api_model,\n",
        "            messages=[{'role': 'user', 'content': prompt}],\n",
        "            max_tokens=max_tokens,\n",
        "            timeout=REQUEST_TIMEOUT\n",
        "        )\n",
        "        return (resp.choices[0].message.content, resp.usage.prompt_tokens, resp.usage.completion_tokens, '')\n",
        "    except Exception as e:\n",
        "        return ('', 0, 0, f'xAI error: {type(e).__name__}: {str(e)[:200]}')\n",
        "\n",
        "\n",
        "def call_deepseek(api_model: str, prompt: str, max_tokens: int) -> tuple:\n",
        "    try:\n",
        "        resp = deepseek_client.chat.completions.create(\n",
        "            model=api_model,\n",
        "            messages=[{'role': 'user', 'content': prompt}],\n",
        "            max_tokens=max_tokens,\n",
        "            timeout=REQUEST_TIMEOUT\n",
        "        )\n",
        "        return (resp.choices[0].message.content, resp.usage.prompt_tokens, resp.usage.completion_tokens, '')\n",
        "    except Exception as e:\n",
        "        return ('', 0, 0, f'DeepSeek error: {type(e).__name__}: {str(e)[:200]}')\n",
        "\n",
        "\n",
        "def call_google(api_model: str, prompt: str, max_tokens: int) -> tuple:\n",
        "    try:\n",
        "        model = genai.GenerativeModel(api_model)\n",
        "        resp = model.generate_content(\n",
        "            prompt,\n",
        "            generation_config={'max_output_tokens': max_tokens},\n",
        "            request_options={'timeout': REQUEST_TIMEOUT}\n",
        "        )\n",
        "        in_tok = getattr(resp.usage_metadata, 'prompt_token_count', 0) if hasattr(resp, 'usage_metadata') else 0\n",
        "        out_tok = getattr(resp.usage_metadata, 'candidates_token_count', 0) if hasattr(resp, 'usage_metadata') else 0\n",
        "        return (resp.text, in_tok, out_tok, '')\n",
        "    except Exception as e:\n",
        "        return ('', 0, 0, f'Google error: {type(e).__name__}: {str(e)[:200]}')\n",
        "\n",
        "\n",
        "PROVIDER_DISPATCH = {\n",
        "    'anthropic': call_anthropic,\n",
        "    'openai': call_openai,\n",
        "    'xai': call_xai,\n",
        "    'deepseek': call_deepseek,\n",
        "    'google': call_google,\n",
        "}\n",
        "\n",
        "print('Dispatchers ready with provider-specific token limits:')\n",
        "for prov, lim in MAX_TOKENS_BY_PROVIDER.items():\n",
        "    print(f'  {prov}: {lim} max_tokens')"
      ]
    },
