        "else:\n",
        "    # Determine starting batch number based on existing checkpoints\n",
        "    checkpoint_dir = f'{PROJECT_ROOT}/stage6/checkpoints'\n",
        "    existing_checkpoints = sorted([f for f in os.listdir(checkpoint_dir) if f.startswith('batch_')]) if os.path.exists(checkpoint_dir) else []\n",
        "    starting_batch = len(existing_checkpoints)\n",
        "\n",
        "    overall_start = time.time()\n",
        "\n",
        "    # Split pending into batches\n",
        "    batches = [pending_calls[i:i+BATCH_SIZE] for i in range(0, len(pending_calls), BATCH_SIZE)]\n",
        "\n",
        "    print(f'Starting execution: {len(pending_calls)} pending calls in {len(batches)} batches')\n",
        "    print(f'First batch index: {starting_batch}')\n",
        "    print()\n",
        "\n",
        "    for batch_idx, batch in enumerate(batches, start=starting_batch):\n",
        "        batch_start = time.time()\n",
        "        batch_responses = []\n",
        "\n",
        "        print(f'=== Batch {batch_idx:03d} ({len(batch)} calls) ===')\n",
        "\n",
        "        for i, call in enumerate(batch, 1):\n",
        "            response = execute_one_call(call)\n",
        "            save_response(response)\n",
        "            batch_responses.append(response)\n",
        "\n",
        "            # Compact per-call status\n",
        "            if response.error:\n",
        "                status = 'ERR'\n",
        "            elif not response.parse_succeeded:\n",
        "                status = 'PFL'  # parse fail\n",
        "            else:\n",
        "                status = 'OK '\n",
        "\n",
        "            # Progress every 20 calls within batch\n",
        "            if i % 20 == 0 or i == len(batch):\n",
        "                elapsed = time.time() - batch_start\n",
        "                rate = i / elapsed if elapsed > 0 else 0\n",
        "                print(f'  [{i:>3}/{len(batch)}] {status} | {response.frame_id:24} | {response.model_id:20} | {rate:.2f} calls/sec')\n",
        "\n",
        "            time.sleep(PACING_SECONDS)\n",
        "\n",
        "        batch_duration = time.time() - batch_start\n",
        "        successes = sum(1 for r in batch_responses if r.parse_succeeded)\n",
        "        parse_fails = sum(1 for r in batch_responses if r.raw_response and not r.parse_succeeded)\n",
        "        errors = sum(1 for r in batch_responses if r.error)\n",
        "\n",
        "        batch_stats = {\n",
        "            'batch_num': batch_idx,\n",
        "            'batch_size': len(batch),\n",
        "            'duration_seconds': batch_duration,\n",
        "            'successes': successes,\n",
        "            'parse_failures': parse_fails,\n",
        "            'errors': errors,\n",
        "            'parse_rate': successes / len(batch) if batch else 0,\n",
