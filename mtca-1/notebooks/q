      "source": [
        "# Check the response directory for already-completed calls\n",
        "responses_dir = f'{PROJECT_ROOT}/stage6/responses'\n",
        "completed_files = set(os.listdir(responses_dir)) if os.path.exists(responses_dir) else set()\n",
        "completed_call_ids = set(f.replace('.json', '') for f in completed_files if f.endswith('.json'))\n",
        "\n",
        "# Filter execution plan to only un-completed calls\n",
        "pending_calls = [c for c in EXECUTION_PLAN if c['call_id'] not in completed_call_ids]\n",
        "\n",
        "print(f'Resume state:')\n",
        "print(f'  Total planned calls: {len(EXECUTION_PLAN)}')\n",
        "print(f'  Already completed: {len(completed_call_ids)}')\n",
        "print(f'  Pending: {len(pending_calls)}')\n",
        "\n",
        "if len(pending_calls) == 0:\n",
        "    print(f'\\nAll calls complete. Skip to Section 6 for final summary.')\n",
        "else:\n",
        "    print(f'\\nWill execute {len(pending_calls)} pending calls.')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "q7vdXjA3YCds"
      },
      "source": [
        "## Section 4: Batched execution\n",
        "\n",
        "Execute pending calls in batches of 200. After each batch, save a checkpoint with progress stats. If Colab disconnects mid-batch, only the in-flight batch's calls need re-attempting on the next run (the call-level skip logic handles this automatically)."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "BawgebRjYCds",
        "outputId": "7246316a-baa4-42b5-ea48-044b2fbdeb02"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Execution helpers defined.\n",
            "Batch size: 200\n",
            "Pacing: 0.3s between calls\n"
          ]
        }
      ],
      "source": [
        "BATCH_SIZE = 200\n",
        "PACING_SECONDS = 0.3  # tighter than pilot (we know dispatchers work)\n",
        "\n",
        "def execute_one_call(call):\n",
        "    \"\"\"Execute a single call from the execution plan. Returns CouncilResponse.\"\"\"\n",
        "    provider = call['provider']\n",
        "    dispatcher = PROVIDER_DISPATCH[provider]\n",
        "    max_tokens = MAX_TOKENS_BY_PROVIDER[provider]\n",
        "\n",
        "    call_start = time.time()\n",
        "    raw, in_tok, out_tok, error = dispatcher(call['api_model'], call['rendered_prompt'], max_tokens)\n",
        "    wall_clock = time.time() - call_start\n",
        "\n",
        "    parsed, parse_ok, parse_err = extract_json_from_response(raw) if raw else ({}, False, 'no response')\n",
        "\n",
        "    return CouncilResponse(\n",
        "        call_id=call['call_id'],\n",
        "        unit_id=call['unit_id'],\n",
        "        text_id=call['text_id'],\n",
        "        frame_id=call['frame_id'],\n",
        "        frame_version=call['frame_version'],\n",
        "        prompt_sha256=call['prompt_sha256'],\n",
        "        model_id=call['model_id'],\n",
        "        provider=call['provider'],\n",
        "        api_model=call['api_model'],\n",
        "        timestamp=datetime.now(timezone.utc).isoformat(),\n",
        "        wall_clock_seconds=wall_clock,\n",
        "        raw_response=raw,\n",
        "        parsed_json=parsed,\n",
        "        parse_succeeded=parse_ok,\n",
        "        parse_error=parse_err,\n",
        "        input_tokens=in_tok,\n",
        "        output_tokens=out_tok,\n",
        "        error=error,\n",
        "        retry_count=0\n",
        "    )\n",
        "\n",
        "\n",
        "def save_response(response: CouncilResponse):\n",
        "    \"\"\"Save response to its individual JSON file.\"\"\"\n",
        "    path = f'{PROJECT_ROOT}/stage6/responses/{response.call_id}.json'\n",
        "    with open(path, 'w', encoding='utf-8') as f:\n",
        "        json.dump(asdict(response), f, indent=2, ensure_ascii=False)\n",
        "\n",
        "\n",
        "def save_checkpoint(batch_num: int, batch_stats: dict):\n",
        "    \"\"\"Save batch summary stats.\"\"\"\n",
        "    path = f'{PROJECT_ROOT}/stage6/checkpoints/batch_{batch_num:03d}.json'\n",
        "    with open(path, 'w', encoding='utf-8') as f:\n",
        "        json.dump(batch_stats, f, indent=2, ensure_ascii=False)\n",
        "\n",
